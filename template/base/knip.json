{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "workspaces": {
    ".": {
      "entry": ["tools/*.mjs", "tools/mcp/**/*.mjs", "tests/rls/*.mjs", "eslint.config.mjs"],
      "project": ["tools/**/*.mjs", "tests/**/*.mjs", "*.{mjs,ts}"],
      "ignoreBinaries": ["drizzle-kit"]
    },
    "apps/desktop": {
      "entry": [
        "src/main.tsx",
        "vite.config.ts",
        "src/**/*.test.{ts,tsx}",
        "tests/unit/**/*.test.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}", "tests/**/*.{ts,tsx}", "*.ts"],
      "ignore": ["src/ipc/bindings.ts"]
    },
    "apps/server": {
      "entry": [
        "src/index.ts",
        "scripts/*.{ts,mjs}",
        "src/**/*.test.ts",
        "tests/unit/**/*.test.ts"
      ],
      "project": ["src/**/*.ts", "scripts/**/*.{ts,mjs}", "tests/**/*.ts"]
    },
    "packages/schema": {
      "entry": ["src/index.ts", "drizzle.config.ts", "src/**/*.test.ts", "tests/unit/**/*.test.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts", "*.ts"]
    },
    "packages/importer": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "tests/unit/**/*.test.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    },
    "packages/eval": {
      "entry": ["src/index.ts", "src/**/*.test.ts", "tests/unit/**/*.test.ts"],
      "project": ["src/**/*.ts", "tests/**/*.ts"]
    }
  }
}
