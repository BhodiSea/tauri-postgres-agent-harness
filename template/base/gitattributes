# Normalize line endings; Windows-only script types keep CRLF.
* text=auto eol=lf
*.ps1 text eol=crlf
*.bat text eol=crlf

# Binary assets
*.png binary
*.ico binary
*.icns binary
*.gguf binary

# Generated-but-committed artifacts: collapse in review, regenerate on drift.
apps/desktop/src/ipc/bindings.ts linguist-generated=true
apps/server/openapi.json linguist-generated=true
pnpm-lock.yaml linguist-generated=true
Cargo.lock linguist-generated=true
