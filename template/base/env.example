# {{PROJECT_NAME}} — environment contract. Copy to .env (gitignored) and fill in.
# Values ship EMPTY by design; the comments describe the local-dev defaults that
# docker-compose.yml + db/init/01-roles.sql provision. No real credential ever
# belongs in this file.

# ---- database ----------------------------------------------------------------
# Connection for the API server. Uses the app_api role: LOGIN, NOSUPERUSER,
# NOBYPASSRLS — every query is subject to FORCE row-level security.
# Local-dev default: role app_api (password: postgres) at 127.0.0.1:5432,
# database {{DB_NAME}}.
DATABASE_URL=

# Connection for drizzle migrations only. Uses the app_migrator role, which owns
# the schema. Never hand this DSN to the API server.
# Local-dev default: role app_migrator (password: postgres), same host/database.
MIGRATOR_DATABASE_URL=

# ---- api server ----------------------------------------------------------------
# Hono server port. Default: 8787.
PORT=
# pino level: trace|debug|info|warn|error. Default: info.
LOG_LEVEL=

# ---- auth ----------------------------------------------------------------------
# stub  = verify against a local JWKS generated by apps/server/scripts/mint-dev-token.mjs
#         (writes .dev-auth/jwks.json; dev only — the server refuses to boot with
#         AUTH_MODE=stub when NODE_ENV=production).
# entra = verify against the tenant's remote JWKS discovered from the IDs below.
AUTH_MODE=
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
API_AUDIENCE=

# ---- desktop (dev only) --------------------------------------------------------
# Origin the SPA calls during `pnpm dev:desktop`. VITE_-prefixed vars are inlined
# into the client bundle — NEVER put a secret behind a VITE_ name.
# Default: {{API_ORIGIN}}
VITE_API_ORIGIN=
