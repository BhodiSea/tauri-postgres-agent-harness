{
  // @app/importer — Node-flavored workspace package (plain ESM, no bundler).
  // Extends the repo-wide max-strict base; NodeNext module semantics are
  // restated here so this package typechecks identically regardless of what
  // resolution the base picks for the app workspaces (packages + server are
  // node16-style, apps/desktop is bundler-style).
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "rootDir": "src",
    "outDir": "dist",
    // TypeScript 6 no longer auto-includes node_modules/@types — node built-in
    // types (node:fs in the fixture tests) must be requested explicitly.
    "types": ["node"]
  },
  "include": ["src"]
}
