{
  "name": "{{PROJECT_SLUG}}",
  "version": "0.1.0",
  "private": true,
  "repository": "github:{{GITHUB_OWNER}}/{{PROJECT_SLUG}}",
  "type": "module",
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "validate": "node tools/validate.mjs",
    "typecheck": "tsc -b",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "biome check --write .",
    "knip": "knip --strict",
    "arch": "depcruise apps packages --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:rls": "node tests/rls/run-rls.mjs",
    "perf:baseline": "node tools/perf-baseline.mjs",
    "spell": "cspell --no-progress --gitignore .",
    "db:up": "docker compose up -d db",
    "db:migrate": "pnpm --filter @app/schema exec drizzle-kit migrate",
    "dev:server": "pnpm --filter server run dev",
    "dev:desktop": "pnpm --filter desktop run dev",
    "openapi:emit": "pnpm --filter server run openapi:emit",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@axe-core/playwright": "catalog:",
    "@biomejs/biome": "catalog:",
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@modelcontextprotocol/sdk": "catalog:",
    "@playwright/test": "catalog:",
    "@vitest/coverage-v8": "catalog:",
    "postgres": "catalog:",
    "cspell": "catalog:",
    "dependency-cruiser": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-jsx-a11y": "catalog:",
    "eslint-plugin-react-hooks": "catalog:",
    "eslint-plugin-sonarjs": "catalog:",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "lefthook": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
