{
  // Standalone project for the Windows E2E lane: discovered by typescript-eslint's
  // projectService so the specs get typed strict lint; never referenced by the
  // root solution build (WDIO/tsx transpile at run time).
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM"],
    "types": []
  },
  "include": ["./**/*.ts"]
}
