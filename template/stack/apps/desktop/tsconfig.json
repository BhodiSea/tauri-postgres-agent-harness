{
  // Desktop SPA: bundler resolution (Vite resolves imports, tsc only checks).
  // Server + packages use node16-style resolution instead — see tsconfig.base.json
  // for the shared max-strict flag set this file inherits.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    // Type-declaration-only emit: Vite owns the JS output, tsc -b needs .d.ts
    // for project references.
    "emitDeclarationOnly": true,
    "outDir": "dist-types",
    "tsBuildInfoFile": "dist-types/tsconfig.tsbuildinfo"
  },
  "include": ["src", "vite.config.ts"],
  "references": [{ "path": "../../packages/schema" }]
}
