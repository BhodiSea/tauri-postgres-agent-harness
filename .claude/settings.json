{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_readme": [
    "Harness-repo development settings: maximally permissive so routine work never prompts.",
    "Only truly irreversible or outward-destructive actions sit in ask/deny; everything else is allowed.",
    "Scratch-tree cleanup under /private/tmp stays prompt-free; recursive deletes aimed at the home tree or the repo cwd prompt first."
  ],
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": ["Bash", "Read", "WebFetch", "WebSearch"],
    "ask": [
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --delete:*)",
      "Bash(git tag -d:*)",
      "Bash(git clean:*)",
      "Bash(rm -rf ~:*)",
      "Bash(rm -rf /Users:*)",
      "Bash(rm -rf .:*)",
      "Bash(rm -rf ..:*)",
      "Bash(sudo:*)",
      "Bash(npm publish:*)",
      "Bash(pnpm publish:*)",
      "Bash(gh release delete:*)",
      "Bash(gh repo delete:*)",
      "Bash(docker compose down -v:*)",
      "Bash(docker volume rm:*)",
      "Bash(docker volume prune:*)",
      "Bash(docker system prune:*)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git push -f:*)",
      "Bash(git reset --hard:*)",
      "Read(./**/.env)",
      "Read(./**/.env.*)",
      "Read(./.dev-auth/**)",
      "Read(~/.ssh/**)"
    ]
  }
}
